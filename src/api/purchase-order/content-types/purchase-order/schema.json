{
  "kind": "collectionType",
  "collectionName": "purchase_orders",
  "info": {
    "singularName": "purchase-order",
    "pluralName": "purchase-orders",
    "displayName": "Purchase_Order"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "OrderDate": {
      "type": "date"
    },
    "TotalAmount": {
      "type": "decimal"
    },
    "PaymentStatus": {
      "type": "enumeration",
      "enum": [
        "Paid",
        "Pending",
        "Cancelled"
      ]
    },
    "ReceivedDate": {
      "type": "date"
    },
    "supplier": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::supplier.supplier",
      "inversedBy": "purchase_order"
    },
    "purchase_order_line": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::purchase-order-line.purchase-order-line",
      "mappedBy": "purchase_order"
    }
  }
}
